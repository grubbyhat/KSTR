# ── KSTR backend secrets ───────────────────────────────────────────────
# Copy to ".env" in this folder and fill in. Never commit the real .env.

# Helius RPC (HTTP). The websocket URL is derived automatically (http->ws).
RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Base58 secret key of the KSTR CREATOR wallet (the wallet that launches KSTR).
# Only the creator can claim KSTR creator fees. This same wallet buys KINS.
WALLET_PRIVATE_KEY=

# Optional: override the websocket RPC URL if it differs from RPC_URL's host.
# RPC_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
